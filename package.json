{
  "name": "@zai/token-command-center",
  "version": "1.1.0",
  "description": "Reusable Command Center panel with sidebar navigation for React/Next.js applications",
  "author": "Z.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sts8987/Token-command-center.git"
  },
  "homepage": "https://github.com/Sts8987/Token-command-center#readme",
  "bugs": {
    "url": "https://github.com/Sts8987/Token-command-center/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/command-center.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/command-center.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/command-center.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "lucide-react": ">=0.300.0"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "keywords": [
    "token-command-center",
    "command-center",
    "token-panel",
    "sidebar",
    "panel",
    "floating-panel",
    "react",
    "nextjs",
    "reusable",
    "command-palette",
    "navigation",
    "lucide"
  ]
}
